{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "paths": {
      "@errors/*": ["./src/errors/*"],
      "@lib/*": ["./src/lib/*"],
      "@routes": ["./src/routes/index.ts"],
      "@routes/*": ["./src/routes/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
